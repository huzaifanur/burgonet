{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Burgonet",
  "version": "0.1.0",
  "identifier": "com.burgonet.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Burgonet",
        "width": 1180,
        "height": 840,
        "minWidth": 820,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "visible": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../dist/burgonet-sidecar/": "sidecar/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
